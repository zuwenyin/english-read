# 服务端口
PORT=3000

# 数据库类型（sqlite / mysql / mongodb）
DB_TYPE=sqlite

# SQLite 数据库文件路径
DB_PATH=./data/english-read.db

# JWT 签名密钥（生产环境请更换为随机字符串）
JWT_SECRET=change-me-to-a-random-string

# 日志级别（error / warn / info / debug）
LOG_LEVEL=info

# DeepSeek API Key（用于生成文章问答和生词标注）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# NewsAPI Key（用于拉取英文新闻，可选，不填则跳过 NewsAPI 源）
NEWSAPI_KEY=your-newsapi-key

# 是否启用定时拉取（true/false，开发环境建议关闭）
CRON_ENABLED=false
